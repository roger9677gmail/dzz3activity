{
  "name": "dzz3activity",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "db:migrate": "bash scripts/db-proxy.sh migrate",
    "db:seed": "bash scripts/db-proxy.sh seed",
    "db:shell": "bash scripts/db-proxy.sh shell",
    "db:proxy": "bash scripts/db-proxy.sh start",
    "gen-vapid": "node -e \"const wp=require('web-push');const keys=wp.generateVAPIDKeys();console.log('NEXT_PUBLIC_VAPID_PUBLIC_KEY='+keys.publicKey);console.log('VAPID_PRIVATE_KEY='+keys.privateKey);\""
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "jose": "^5.9.6",
    "mysql2": "^3.22.3",
    "next": "14.2.18",
    "nodemailer": "^6.9.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17"
  }
}
